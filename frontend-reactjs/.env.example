# Base URL of the API Gateway HTTP API (see docs/api.md). In local dev this
# is usually left unset — vite.config.ts already proxies /v1 to :8080.
VITE_API_URL=http://localhost:8080

# Cognito User Pool used for real sign-in (frontend-reactjs/src/lib/auth.ts).
# Leave both unset to run against a backend with auth disabled.
VITE_USER_POOL_ID=
VITE_USER_POOL_CLIENT_ID=
