# MCP Server Configuration
# Copy this file to .env and fill in your actual values

# ==================== Claude API ====================
# Get from: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-YOUR-KEY-HERE
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_API_URL=https://api.anthropic.com/v1/messages

# ==================== Slack ====================
# Bot Token: https://api.slack.com/apps/
SLACK_BOT_TOKEN=xoxb-YOUR-BOT-TOKEN-HERE
SLACK_ADMIN_TOKEN=xoxp-YOUR-ADMIN-TOKEN-HERE  # Optional

# OAuth (for dynamic authentication)
SLACK_CLIENT_ID=YOUR-SLACK-CLIENT-ID
SLACK_CLIENT_SECRET=YOUR-SLACK-CLIENT-SECRET
SLACK_OAUTH_REDIRECT_URI=http://localhost:8000/mcp/oauth/slack/callback

# ==================== Jira ====================
# Email: your@organization.com
# API Token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL=user@organization.com
JIRA_API_TOKEN=YOUR-JIRA-API-TOKEN-HERE
JIRA_DOMAIN=https://your-organization.atlassian.net

# OAuth (for dynamic authentication)
JIRA_CLIENT_ID=YOUR-JIRA-CLIENT-ID
JIRA_CLIENT_SECRET=YOUR-JIRA-CLIENT-SECRET
JIRA_OAUTH_REDIRECT_URI=http://localhost:8000/mcp/oauth/jira/callback

# ==================== Server Configuration ====================
MCP_SERVER_PORT=8000

# ==================== System Prompt ====================
CLAUDE_SYSTEM_PROMPT=Bạn là trợ lý AI của một tổ chức phi lợi nhuận tại Việt Nam. Luôn trả lời bằng tiếng Việt, rõ ràng, ngắn gọn và chuyên nghiệp.
